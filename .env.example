# =============================================================================
# App Home Services - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running the service.
#   cp .env.example .env
# =============================================================================

# -- Database -----------------------------------------------------------------
# PostgreSQL connection string for the app database.
# Format: postgres://<user>:<password>@<host>/<database>
DATABASE_URL=postgres://user:pass@localhost/app_home

# -- Default Local User -------------------------------------------------------
# Credentials for the pre-seeded admin user (auth_provider = 'local').
# This user is created automatically on first startup if it doesn't exist.
DEFAULT_USER_USERNAME=admin
DEFAULT_USER_PASSWORD=<your-secure-password>
DEFAULT_USER_EMAIL=admin@example.com

# -- Google OAuth -------------------------------------------------------------
# OAuth 2.0 Client ID from Google Cloud Console.
# Leave empty to disable Google login.
GOOGLE_CLIENT_ID=<your-google-client-id>

# -- Server -------------------------------------------------------------------
# Host and port the HTTP server will bind to.
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# -- JWT ----------------------------------------------------------------------
# Secret key used to sign and verify JWT tokens (access + refresh).
# Generate a strong random key, e.g.: openssl rand -hex 64
JWT_SECRET=<your-jwt-secret>

# Access token lifetime in minutes (default: 15).
ACCESS_TOKEN_EXPIRY_MINUTES=15

# Refresh token lifetime in days (default: 7).
REFRESH_TOKEN_EXPIRY_DAYS=7

# -- Rate Limiting ------------------------------------------------------------
# Maximum number of failed login attempts per IP within the time window.
RATE_LIMIT_MAX_ATTEMPTS=10

# Rate limit window in seconds (default: 300 = 5 minutes).
RATE_LIMIT_WINDOW_SECONDS=300

# -- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed origins for cross-origin requests.
# Leave empty to deny all cross-origin access (same-origin only).
CORS_ALLOWED_ORIGINS=
