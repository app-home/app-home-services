# =============================================================================
# App Home Services - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running the service.
#   cp .env.example .env
# =============================================================================

# -- Database -----------------------------------------------------------------
# PostgreSQL connection string for the app database.
# Format: postgres://<user>:<password>@<host>/<database>
DATABASE_URL=postgres://user:pass@localhost/app_home

# -- Default Local User -------------------------------------------------------
# Credentials for the pre-seeded admin user (auth_provider = 'local').
# This user is created automatically on first startup if it doesn't exist.
DEFAULT_USER_USERNAME=admin
DEFAULT_USER_PASSWORD=<your-secure-password>
DEFAULT_USER_EMAIL=admin@example.com

# -- Google OAuth -------------------------------------------------------------
# OAuth 2.0 Client ID from Google Cloud Console.
# Leave empty to disable Google login.
GOOGLE_CLIENT_ID=<your-google-client-id>

# -- Server -------------------------------------------------------------------
# Host and port the HTTP server will bind to.
# Default if unset: 127.0.0.1 (loopback only, local connections accepted).
# Set to 0.0.0.0 when running in a container or anywhere else the process needs
# to accept connections from outside its own host -- see the README's Container
# Image section: the published image does NOT set this for you, so running it
# without SERVER_HOST=0.0.0.0 starts successfully but is unreachable.
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# -- JWT ----------------------------------------------------------------------
# Secret key used to sign and verify JWT tokens (access + refresh).
# Must be at least 32 bytes long AND have at least 8 unique characters -- the
# service refuses to start otherwise, since a short or low-diversity secret
# (e.g. "aaaa...aaaa") makes tokens forgeable via brute force against the HS256
# signing key. Generate a strong random key, e.g.: openssl rand -hex 64
JWT_SECRET=<your-jwt-secret>

# Access token lifetime in minutes (default: 15).
ACCESS_TOKEN_EXPIRY_MINUTES=15

# Refresh token lifetime in days (default: 7).
REFRESH_TOKEN_EXPIRY_DAYS=7

# -- Rate Limiting ------------------------------------------------------------
# Maximum number of failed login attempts per IP within the time window.
RATE_LIMIT_MAX_ATTEMPTS=10

# Rate limit window in seconds (default: 300 = 5 minutes).
RATE_LIMIT_WINDOW_SECONDS=300

# Redis connection URL used to store rate-limit counters.
#
# Leave empty to use an in-memory rate limiter instead -- this is only safe when
# running a single instance of this service, since in-memory counters aren't shared
# across restarts or replicas. Set this whenever the service runs behind a load
# balancer with more than one instance, so the rate limit stays effective.
#
# Formats supported (passed through to the `redis` crate as-is):
#   redis://[:password@]host:port[/db]   -- standard connection, optional auth
#   rediss://[:password@]host:port[/db]  -- TLS-enabled connection
#
# Environment / namespace isolation: rate-limit keys use a fixed prefix
# (ratelimit:login:{ip} / ratelimit:refresh:{ip}) with no environment
# discriminator baked in. If staging and production (or multiple services) ever
# share a single Redis deployment, point each environment at a different logical
# database via the URL's /<db> suffix (e.g. REDIS_URL=redis://host:6379/0 for
# staging, redis://host:6379/1 for production) or, better, use entirely separate
# Redis instances -- otherwise rate-limit counters from different environments
# could collide.
#
# Example: REDIS_URL=redis://127.0.0.1:6379
# Example with auth: REDIS_URL=redis://:mypassword@127.0.0.1:6379
# Example with TLS: REDIS_URL=rediss://:mypassword@my-redis-host:6380
REDIS_URL=

# -- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed origins for cross-origin requests.
# Leave empty to deny all cross-origin access (same-origin only).
CORS_ALLOWED_ORIGINS=

# -- Trusted Proxies ------------------------------------------------------------
# Comma-separated list of IP addresses for reverse proxies / load balancers that
# sit directly in front of this service (e.g. an nginx sidecar, ingress controller,
# or internal load balancer IP).
#
# Only requests whose direct TCP peer address is in this list will have their
# X-Forwarded-For / X-Real-IP headers trusted for rate limiting. Any other request
# has those headers ignored and the real socket peer address is used instead, since
# otherwise any client could spoof these headers to bypass rate limiting entirely.
#
# Leave empty if this service is reached directly (no reverse proxy in front of it).
# Example: TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2
TRUSTED_PROXY_IPS=
